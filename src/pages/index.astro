---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/mygo-kg';
---
<BaseLayout title="Home" description="BanG Dream! It's MyGO!!!!! & Ave Mujica Knowledge Graph Archive">
  <section class="hero">
    <h1>MyGO Knowledge Graph Archive</h1>
    <p class="subtitle">
      A searchable, interconnected knowledge network for
      <em>BanG Dream! It's MyGO!!!!!</em> and <em>Ave Mujica</em>
    </p>
  </section>

  <section class="entry-points">
    <h2>Explore</h2>
    <div class="card-grid">
      <a href={`${base}/characters`} class="card">
        <h3>Characters</h3>
        <p>Browse all characters and their relationships</p>
      </a>
      <a href={`${base}/songs`} class="card">
        <h3>Songs</h3>
        <p>Explore songs, lyrics, and connections</p>
      </a>
      <a href={`${base}/episodes`} class="card">
        <h3>Episodes</h3>
        <p>Navigate episode content and annotations</p>
      </a>
      <a href={`${base}/events`} class="card">
        <h3>Events</h3>
        <p>Key events in the MyGO and Ave Mujica story</p>
      </a>
      <a href={`${base}/radio`} class="card">
        <h3>Radio</h3>
        <p>Radio show transcripts and highlights</p>
      </a>
      <a href={`${base}/interviews`} class="card">
        <h3>Interviews</h3>
        <p>Official and magazine interviews</p>
      </a>
      <a href={`${base}/lives`} class="card">
        <h3>Lives</h3>
        <p>Live performance reports and setlists</p>
      </a>
      <a href={`${base}/tags`} class="card">
        <h3>Tags</h3>
        <p>Browse by themes and topics</p>
      </a>
    </div>
  </section>

  <section class="tools">
    <h2>Tools</h2>
    <div class="card-grid">
      <a href={`${base}/timeline`} class="card">
        <h3>Timeline</h3>
        <p>Explore events chronologically</p>
      </a>
      <a href={`${base}/graph`} class="card">
        <h3>Knowledge Graph</h3>
        <p>Visualize the knowledge network</p>
      </a>
      <a href={`${base}/search`} class="card">
        <h3>Search</h3>
        <p>Full-text search across the archive</p>
      </a>
    </div>
  </section>
</BaseLayout>